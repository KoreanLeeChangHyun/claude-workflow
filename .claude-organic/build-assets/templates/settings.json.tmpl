{
  "statusLine": {
    "type": "command",
    "command": "python3 -u $CLAUDE_PROJECT_DIR/.claude-organic/engine/statusline.py"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|compact|clear",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u $CLAUDE_PROJECT_DIR/.claude-organic/engine/sync/history_sync.py sync && python3 -u $CLAUDE_PROJECT_DIR/.claude-organic/engine/sync/history_sync.py archive",
            "timeout": 30,
            "async": true
          }
        ]
      },
      {
        "matcher": "startup|resume|compact|clear",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u $CLAUDE_PROJECT_DIR/.claude-organic/board/server.py",
            "timeout": 5,
            "async": true
          }
        ]
      },
      {
        "matcher": "startup|resume|compact|clear",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u $CLAUDE_PROJECT_DIR/.claude-organic/hooks/session-start.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u $CLAUDE_PROJECT_DIR/.claude-organic/hooks/pre-tool-use.py",
            "statusMessage": "pre-tool-use 디스패처 실행 중..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u $CLAUDE_PROJECT_DIR/.claude-organic/hooks/subagent-stop.py",
            "timeout": 10,
            "statusMessage": "subagent-stop 디스패처 실행 중..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u $CLAUDE_PROJECT_DIR/.claude-organic/hooks/post-tool-use.py",
            "timeout": 30,
            "async": true,
            "statusMessage": "post-tool-use 디스패처 실행 중..."
          }
        ]
      }
    ]
  }
}
