{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Edit(.claude-organic/scripts/**)",
      "Edit(.claude-organic/hooks/**)",
      "Edit(.claude-organic/prompt/**)",
      "Edit(.claude-organic/docs/**)",
      "Edit(.claude-organic/init/**)",
      "Edit(.claude-organic/board/**)",
      "Edit(.claude/skills/**)",
      "Edit(.claude/agents/**)",
      "Edit(.claude/commands/**)",
      "Edit(.claude/rules/**)",
      "Write(.claude/skills/**)",
      "Write(.claude/agents/**)",
      "Write(.claude/commands/**)",
      "Write(.claude/rules/**)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 -u $CLAUDE_PROJECT_DIR/.claude-organic/scripts/statusline.py"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|compact|clear",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u $CLAUDE_PROJECT_DIR/.claude-organic/scripts/sync/history_sync.py sync && python3 -u $CLAUDE_PROJECT_DIR/.claude-organic/scripts/sync/history_sync.py archive",
            "timeout": 30,
            "async": true
          }
        ]
      },
      {
        "matcher": "startup|resume|compact|clear",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u $CLAUDE_PROJECT_DIR/.claude-organic/board/server.py",
            "timeout": 5,
            "async": true
          }
        ]
      },
      {
        "matcher": "startup|resume|compact|clear",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u $CLAUDE_PROJECT_DIR/.claude-organic/hooks/session-start.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u $CLAUDE_PROJECT_DIR/.claude-organic/hooks/pre-tool-use.py",
            "statusMessage": "pre-tool-use 디스패처 실행 중..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u $CLAUDE_PROJECT_DIR/.claude-organic/hooks/subagent-stop.py",
            "timeout": 10,
            "statusMessage": "subagent-stop 디스패처 실행 중..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u $CLAUDE_PROJECT_DIR/.claude-organic/hooks/post-tool-use.py",
            "timeout": 30,
            "async": true,
            "statusMessage": "post-tool-use 디스패처 실행 중..."
          }
        ]
      }
    ]
  }
}
