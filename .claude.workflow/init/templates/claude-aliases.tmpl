# 이 파일은 build.sh가 생성합니다.
# Claude Code workflow aliases
export PATH="$HOME/.local/bin:$PATH"

# flow-* wrapper (프로젝트별 동적 PATH)
_cwf_root="$(git rev-parse --show-toplevel 2>/dev/null)"
if [ -n "$_cwf_root" ] && [ -d "$_cwf_root/.claude.workflow/bin" ]; then
  export PATH="$_cwf_root/.claude.workflow/bin:$PATH"
fi
unset _cwf_root

alias cc='claude --dangerously-skip-permissions'
alias ccc='claude --dangerously-skip-permissions --continue'
alias ccv='claude --dangerously-skip-permissions'
cct() {
  local i=0 name="main"
  while tmux has-session -t "$name" 2>/dev/null; do
    name="main-$((++i))"
  done
  tmux new-session -s "$name" "claude --dangerously-skip-permissions"
}
